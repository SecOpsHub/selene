# Selene - Filebeat Configuration
# Managed by Ansible (site.yml section 4) - do not edit directly.
# Ships Wazuh alerts to Amazon OpenSearch Service.

filebeat.modules:
  - module: wazuh
    alerts:
      enabled: true
    archives:
      enabled: false

setup.template.json.enabled: true
setup.template.json.path: /etc/filebeat/wazuh-template.json
setup.template.json.name: wazuh
setup.template.name: wazuh
setup.template.pattern: wazuh-alerts-4.x-*
setup.template.overwrite: true
setup.ilm.enabled: false
# Disable pipeline loading — Amazon OpenSearch Service does not support
# the geoip ingest processor used by the Wazuh filebeat module pipeline.
pipeline: ""

# ── Output: Amazon OpenSearch Service ─────────────────────────
# Password sourced from SSM SecureString /selene/opensearch_admin_password
output.elasticsearch:
  hosts:
    - "https://{{ opensearch_endpoint }}:443"
  username: "admin"
  password: "{{ opensearch_admin_password }}"
  ssl:
    verification_mode: none
  index: "wazuh-alerts-4.x-%{+yyyy.MM.dd}"
  pipeline: ""

logging.level: info
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat
  keepfiles: 7
  permissions: 0644
